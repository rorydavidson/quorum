# Quorum — root Docker Compose environment variables
#
# Copy this file to .env at the repo root (alongside docker-compose.yml)
# and fill in all values for your environment.
#
# This file is read automatically by `docker compose` for variable
# interpolation in docker-compose.yml and docker-compose.prod.yml.
#
# NEVER commit .env — it is listed in .gitignore.
# This .env.example file IS committed as a reference template.

# ── Database ──────────────────────────────────────────────────────────────────
# Shared between the postgres service and the BFF DATABASE_URL.
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── URLs & cookies ────────────────────────────────────────────────────────────
# Full public URL of the portal (no trailing slash).
#   Local dev:   http://localhost
#   Production:  https://your.domain.com
PUBLIC_URL=https://CHANGE_ME_DOMAIN

# Must be "true" when serving over HTTPS.
# Browsers refuse to send Secure cookies over plain HTTP, breaking OIDC login.
#   Local dev (HTTP):    false
#   Production (HTTPS):  true
COOKIE_SECURE=true

# ── Port mappings (host ports) ────────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443

# ── Let's Encrypt (production only — used by docker-compose.prod.yml) ─────────
# Domain name only — no https:// prefix. Must match nginx-prod.conf server_name.
DOMAIN=CHANGE_ME_DOMAIN

# Email for Let's Encrypt account registration and certificate expiry alerts.
CERTBOT_EMAIL=admin@CHANGE_ME_DOMAIN
