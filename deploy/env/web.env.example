# Quorum Web — production environment template
# Copy to web.env and fill in values as needed.
# This file is checked into git. web.env is NOT (see .gitignore).

NODE_ENV=production
PORT=3000
# Bind to localhost only — nginx handles external traffic
HOSTNAME=127.0.0.1

# ── BFF URL ──────────────────────────────────────────────────────────────────
# Server-to-server call (NOT NEXT_PUBLIC_). No TLS needed for localhost.
BFF_URL=http://127.0.0.1:3001

# ── Public config ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Quorum

# ── Discourse ────────────────────────────────────────────────────────────────
# Must match the BFF value
DISCOURSE_URL=https://forums.snomed.org
