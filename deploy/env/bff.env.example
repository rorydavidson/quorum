# Quorum BFF — production environment template
# Copy to bff.env and fill in all CHANGE_ME values.
# This file is checked into git. bff.env is NOT (see .gitignore).

NODE_ENV=production
PORT=3001

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# For local PostgreSQL:
#   DATABASE_URL=postgresql://quorum:<password>@127.0.0.1:5432/quorum
# For AWS RDS or other managed service:
#   DATABASE_URL=postgresql://quorum:<password>@your-rds-endpoint.rds.amazonaws.com:5432/quorum
DATABASE_URL=postgresql://quorum:CHANGE_ME@127.0.0.1:5432/quorum

# ── Keycloak OIDC ────────────────────────────────────────────────────────────
KEYCLOAK_URL=https://snoauth.ihtsdotools.org
KEYCLOAK_REALM=snomed
KEYCLOAK_CLIENT_ID=quorum
KEYCLOAK_CLIENT_SECRET=CHANGE_ME
# Must match the public URL (via nginx), not localhost
KEYCLOAK_REDIRECT_URI=https://CHANGE_ME_DOMAIN/auth/callback

# ── Session ──────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=CHANGE_ME_MIN_32_CHARS
SESSION_COOKIE_NAME=quorum_session

# ── Google APIs (Service Account) ────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL=CHANGE_ME@CHANGE_ME.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nCHANGE_ME\n-----END PRIVATE KEY-----\n"
GOOGLE_PROJECT_ID=CHANGE_ME

# ── Frontend origin (for CORS) ──────────────────────────────────────────────
# Must match the public URL including scheme, no trailing slash
FRONTEND_ORIGIN=https://CHANGE_ME_DOMAIN

# ── Discourse ────────────────────────────────────────────────────────────────
DISCOURSE_URL=https://forums.snomed.org
# Uncomment for private/restricted categories:
# DISCOURSE_API_KEY=CHANGE_ME
# DISCOURSE_API_USERNAME=quorum-system
