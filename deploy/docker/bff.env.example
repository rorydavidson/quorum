# Quorum BFF — Docker environment template
# Copy to bff.env and fill in all CHANGE_ME values.
# Variables set in docker-compose.yml (DATABASE_URL, PORT, NODE_ENV, FRONTEND_ORIGIN)
# do NOT need to be duplicated here — compose values take precedence.

# ── Keycloak OIDC ────────────────────────────────────────────────────────────
KEYCLOAK_URL=https://CHANGE_ME
KEYCLOAK_REALM=CHANGE_ME
KEYCLOAK_CLIENT_ID=quorum
KEYCLOAK_CLIENT_SECRET=CHANGE_ME

# MUST be the public URL as seen by the browser (through nginx), NOT an internal URL.
# Must match what is registered in Keycloak as a valid redirect_uri.
KEYCLOAK_REDIRECT_URI=https://CHANGE_ME_DOMAIN/auth/callback

# ── Session ──────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=CHANGE_ME_MIN_32_CHARS
SESSION_COOKIE_NAME=quorum_session

# ── Google APIs (Service Account) ────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL=CHANGE_ME@CHANGE_ME.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nCHANGE_ME\n-----END PRIVATE KEY-----\n"
GOOGLE_PROJECT_ID=CHANGE_ME

# ── Discourse ────────────────────────────────────────────────────────────────
DISCOURSE_URL=https://CHANGE_ME
# Uncomment for private/restricted categories:
# DISCOURSE_API_KEY=CHANGE_ME
# DISCOURSE_API_USERNAME=quorum-system

# ── Dev auth bypass (local testing without Keycloak) ─────────────────────────
# Uncomment to skip Keycloak entirely (uses a fake admin user):
# DEV_AUTH_BYPASS=true
