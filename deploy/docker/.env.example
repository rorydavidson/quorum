# Docker Compose root variables
# Copy to .env in the same directory (deploy/docker/.env)

# PostgreSQL password — shared between postgres service and BFF DATABASE_URL
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Public URL — used for FRONTEND_ORIGIN (CORS + post-login redirect)
# Local dev:   http://localhost
# Production:  https://quorum.snomed.org
PUBLIC_URL=http://localhost

# Session cookie Secure flag — set to "true" only when TLS is enabled.
# Browsers reject Secure cookies over plain HTTP, breaking OIDC login.
# Local dev (HTTP):  false
# Production (HTTPS): true
COOKIE_SECURE=false

# Port mapping (host ports)
HTTP_PORT=80
HTTPS_PORT=443
