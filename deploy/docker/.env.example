# Quorum — Docker Compose local dev variables
#
# This file documents the variables used by docker-compose.yml.
# For local dev: copy to deploy/docker/.env and adjust as needed.
# For production: create a .env at the REPO ROOT (see .env.example there).
#
# Note: the recommended approach is a root .env — Docker Compose picks it
# up automatically without needing --env-file flags.

# PostgreSQL password — shared between postgres service and BFF DATABASE_URL
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Public URL — used for FRONTEND_ORIGIN (CORS + post-login redirect)
# Local dev:   http://localhost
# Production:  https://your.domain.com
PUBLIC_URL=http://localhost

# Session cookie Secure flag — set to "true" only when TLS is enabled.
# Browsers reject Secure cookies over plain HTTP, breaking OIDC login.
# Local dev (HTTP):   false
# Production (HTTPS): true
COOKIE_SECURE=false

# Port mapping (host ports)
HTTP_PORT=80
HTTPS_PORT=443

# ── Production TLS (used by docker-compose.prod.yml) ─────────────────────────
# Domain name only — no https:// prefix. Must match nginx-prod.conf server_name.
# DOMAIN=your.domain.com

# Email for Let's Encrypt account registration and expiry alerts.
# CERTBOT_EMAIL=admin@your.domain.com
